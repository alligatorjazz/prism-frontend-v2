					<li><a href="/">Way you can get involved</a></li>
					<li><a href="/">Way you can get involved</a></li>
				</ul>
			</div>
		</div>
	</section>
	<section class="task-force" id="outreach">
		<div class="container">
			<div class="info">
				<div class="text">
					<h1>Outreach Task Force</h1>
					<p>
						The Outreach Task Force coordinates events and other activities to
						spread awareness of the amazing work PRISM does and build
						connections with the community.
					</p>
					<p>
						<b
							>The Outreach Task Force coordinates events and other activities
