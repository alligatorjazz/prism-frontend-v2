					<li><a href="/">Way you can get involved</a></li>
				</ul>
			</div>
		</div>
	</section>
</Base>

<style>
	#introduction {
		color: white;
		text-align: center;
		padding: 2rem;
		h1 {
			font-size: 3rem;
			margin: 0;
		}
		p {
			margin: 0;
			font-size: 1.5rem;
		}
	}

	#internal-nav {
		width: 100%;
		display: flex;
		position: sticky;
		top: 10rem;
		background: var(--bg-color);
		transition: all 300ms;
		a {
			padding: 1rem;
			display: block;
			border-right: 1px solid white;
			border-bottom: 1px solid white;
			flex: 1;
			text-align: center;
			font-weight: bold;
			&:last-child {
				border-right: 0;
			}
			font-family: var(--header-font);
			text-decoration: none;
			color: white;
			&:visited {
				color: white;
			}
		}
	}
	body[data-prev-scroll="down"] #internal-nav {
		top: 0rem;
	}
	#research {
		color: white;
		background: blue;
	}

	#content-creation {
		color: black;
		background: yellow;
	}
	#fundraising {
		color: white;
		background: green;
	}
	#outreach {
		color: white;
		background: orange;
	}

	#policy {
		color: white;
		background: red;
	}

	.task-force {
		padding: 2rem;
		width: 100%;
		.container {
			margin: auto;

			max-width: var(--xl);
		}

		.info {
			display: flex;
			align-items: center;
			gap: 2rem;
			.text {
				flex: 1;
				h1 {
					padding-bottom: 1rem;
					font-size: 2.5rem;
					border-bottom: 2px solid white;
				}
				p {
					font-size: 1.5rem;
				}
			}
			.image {
				width: 30%;
				img {
					width: 100%;
					height: 100%;
					object-fit: contain;
				}
			}
		}

		.team-member {
			display: flex;
			align-items: center;
			gap: 2rem;

			.text {
				flex: 1;
				p {
					font-size: 1.5rem;
				}

				.topline {
					h2 {
						font-size: 2rem;
						margin: 0;
					}
					p {
						margin: 0;
						font-style: italic;
					}
					padding-bottom: 1rem;
					border-bottom: 2px solid white;
				}
			}

			.image {
				width: 30%;
				img {
					width: 100%;
					height: 100%;
					object-fit: contain;
				}
			}
		}

		.get-involved {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 4rem;
			a {
				text-decoration: none;
			}
			a:visited {
				color: inherit;
			}
			h2 {
				font-size: 2rem;
			}
			ul {
				font-size: 1.5rem;
			}
		}
	}
</style>
