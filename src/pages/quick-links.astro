---
import { faker } from "@faker-js/faker";
import Base from "../templates/Base.astro";
import { toTitleCase } from "../lib/dom";

const quickLinks: { label: string; href: string; color?: string }[] =
	Array.from({ length: 7 }, () => ({
		label: toTitleCase(faker.lorem.words({ min: 3, max: 6 })),
		href: "/",
		color: ["var(--bg-color)", "blue", "red", "green", "orange"][
			Math.floor(Math.random() * 5)
		],
	}));
---

<Base
	pageMetadata={{
		title: "Quick Links",
		description: "See the breath and depth of PRISM's work.",
		type: "website",
		image: "https://picsum.photos/200",
		"image:alt": "test",
	}}
>
	<div class="container">
		<h1>Quick Links</h1>
		<ul>
			{
				quickLinks.map(({ label, href, color }) => (
					<li style={{ backgroundColor: color }}>
						<a href={href}>{label}</a>
					</li>
				))
			}
		</ul>
	</div>
</Base>

<style>
	.container {
		padding: 4rem;
		margin: auto;
		margin-top: 10rem;
		max-width: var(--lg);

		h1 {
			font-size: 2rem;
			font-family: var(--header-font);
			margin-bottom: 2rem;
			text-align: center;
			color: var(--fg-color);
		}

		ul {
			list-style: none;
			margin: 0;
			display: flex;
			flex-direction: column;
			gap: 1rem;
			text-align: center;

			li {
				border-radius: 10px;
				border: 4px solid white;
				padding: 1rem;
				font-size: 1.25rem;

				a {
					width: 100%;
					height: 100%;
					text-decoration: none;
					color: var(--fg-color);
					font-family: var(--header-font);
				}
			}
		}
	}
</style>
