---
import Base from "../templates/Base.astro";
import { Image } from "astro:assets";
import logo from "../assets/img/prism-logo-primary.png";
import ToString from "../components/ToString.astro";
import centerLink from "../assets/img/centerlink-badge.png";
import { Icon } from "astro-icon/components";
import FlagWithTagline from "../sections/FlagWithTagline.astro";
import flag from "../assets/img/long-pride-flag.png";
import CenteredPaperWithHeader from "../sections/CenteredPaperWithHeader.astro";
import ColoredHeader from "../sections/ColoredHeader.astro";
import CardsWithHeader from "../sections/CardsWithHeader.astro";

const fakeEvents = [];
---

<Base
	pageMetadata={{
		title: "Website",
		description: "Test",
		type: "website",
		image: "https://picsum.photos/200",
		"image:alt": "test",
	}}
>
	<section id="animated-hero"></section>
	<FlagWithTagline title="Tagline" image={{ alt: "A pride flag.", ...flag }}>
		<ToString slot="center">
			<div
				style={{
					fontSize: "4.5rem",
					fontFamily: "var(--header-font)",
					fontWeight: "600",
					lineHeight: "5rem",
					color: "var(--fg-color)",
				}}
			>
				<p>For every color,<br />For everyone</p>
			</div>
		</ToString>
	</FlagWithTagline>
	<CenteredPaperWithHeader title="Our Mission">
		<h1
			style={{ fontSize: "4.5rem", fontWeight: "600", lineHeight: "5rem" }}
			slot="header"
		>
			Our Mission
		</h1>
		<p slot="content">
			PRISM works to expand access to LGBTQ-inclusive education and sexual
			health resources for youth in South Florida. It's our goal to make sure
			everyone feels included in their community, regardless of race, ethnicity,
			religion, sexual orientation, gender identity, or gender expression.
		</p>
	</CenteredPaperWithHeader>
	<CardsWithHeader
		title="Resources"
		cards={[
			{ label: "Learn", background: "yellow", href: "/", textColor: "black" },
			{ label: "Student Ambassador Program", background: "purple", href: "/" },
			{ label: "Get Tested", background: "pink", href: "/" },
			{ label: "School Policy Hub", background: "blue", href: "/" },
		]}
	/>
	<section id="upcoming-events">
		<div><h1>Upcoming Events</h1></div>
		<div>
			<ul>
				<li><a href="/"><div></div></a></li>
				<li><a href="/"><div></div></a></li>
				<li><a href="/"><div></div></a></li>
			</ul>
			<div>
				<button type="button">1</button>
				<button type="button">2</button>
				<button type="button">3</button>
				<button type="button">4</button>
				<button type="button">5</button>
				<button type="button">6</button>
			</div>
		</div>
	</section>
	<section id="our-partners">
		<p>
			PRISM prides itself in being a collaborative member of the LGBT community
			in South Florida. See some of our partners below! These organizations,
			businesses, and individuals have shown their steadfast commitment to our
			motto: "For Every Color, For Everyone" through partnered events,
			fundraising initiatives, grants, sponsorships, and other collaborations.
		</p>
		<ul>
			<li><a href=""><div></div> </a></li>
			<li><a href=""><div></div> </a></li>
			<li><a href=""><div></div> </a></li>
			<li><a href=""><div></div> </a></li>
			<li><a href=""><div></div> </a></li>
		</ul>
	</section>
	<section id="newsletter-signup">
		<form name="newsletter-signup">
			<p>Subscribe to our Newsletter</p>
			<div>
				<label for="first-name">First Name</label>
				<input type="text" name="first-name" />
			</div>
			<div>
				<label for="last-name">Last Name</label>
				<input type="text" name="last-name" />
			</div>
			<div>
				<label for="email">Email</label>
				<input type="email" name="email" />
			</div>
			<button type="submit">Subscribe</button>
		</form>
	</section>
	<footer>
		<div>
			<div>
				<Image src={logo} alt={"placeholder"} />
				<p>© 2020-{`${new Date().getFullYear()}`}by PRISM FL, Inc.</p>
			</div>
			<div>
				<p>Phone: (561) 291-9207</p>
				<p>Email: info@prismfl.org</p>
				<ul>
					<li>
						<a name="placeholder" href="/404"><Icon name="ri:discord-fill" /></a
						>
					</li>
					<li>
						<a name="placeholder" href="/404"><Icon name="ri:tiktok-fill" /></a>
					</li>
					<li>
						<a name="placeholder" href="/404"
							><Icon name="ri:youtube-fill" />
						</a>
					</li>
					<li>
						<a name="placeholder" href="/404"
							><Icon name="ri:instagram-fill" />
						</a>
					</li>
					<li>
						<a name="placeholder" href="/404"
							><Icon name="ri:facebook-fill" />
						</a>
					</li>
				</ul>
			</div>
			<div>
				<Image src={centerLink} alt="placeholder" />
			</div>
		</div>
		<div>
			<p>
				PRISM FL, Inc (EIN: 85-0891778) is a tax-exempt non-profit organization
				under Internal Revenue Code (IRC) section 501(c)(3). Donations and other
				contributions to PRISM FL, Inc. are tax-deductible under IRC Section
				170.
			</p>
			<p>
				"A COPY OF THE OFFICIAL REGISTRATION AND FINANCIAL INFORMATION OF PRISM
				FL, INC, CH62359, MAY BE OBTAINED FROM THE DIVISION OF CONSUMER SERVICES
				BY CALLING TOLL-FREE (800-435-7352) WITHIN THE STATE. REGISTRATION DOES
				NOT IMPLY ENDORSEMENT, APPROVAL, OR RECOMMENDATION BY THE STATE."
			</p>
		</div>
	</footer>
</Base>

<style>
	#animated-hero {
		/* temp */
		height: 60vh;
		background-color: darkmagenta;
	}
</style>
