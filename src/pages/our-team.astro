---
import { faker } from "@faker-js/faker";
import Base from "../templates/Base.astro";
import { toTitleCase } from "../lib/dom";
import { repeatRandom } from "../lib";
import PageIntro from "../sections/PageIntro.astro";

const fakeTeamMember = () => {
	return {
		title: toTitleCase(faker.lorem.words(2)),
		name: toTitleCase(faker.person.fullName()),
		pronouns: ["he/him", "she/her", "they/them"][Math.floor(Math.random() * 3)],
		description: faker.lorem.sentences(2),
		email: faker.internet.email(),
		image: faker.image.avatarGitHub(),
		contactFor: faker.lorem.words({ min: 3, max: 9 }),
	};
};

const fakeBoardMember = () => {
	return {
		title: toTitleCase(faker.lorem.words(2)),
		name: toTitleCase(faker.person.fullName()),
		pronouns: ["he/him", "she/her", "they/them"][Math.floor(Math.random() * 3)],
		description: faker.lorem.sentences(2),
		image: faker.image.avatarGitHub(),
		email: faker.internet.email(),
	};
};

const team = repeatRandom(fakeTeamMember, 5, 8);
const board = repeatRandom(fakeBoardMember, 5, 8);
---

<Base
	pageMetadata={{
		title: "Our Team",
		description: "Meet PRISM's team and board.",
		type: "website",
		image: "https://picsum.photos/200",
		"image:alt": "test",
	}}
>
	<section id="our-team">
		<!-- <h1>Our Team</h1> -->
		<PageIntro title={"Our Team"} description="Learn about PRISM's team!" />
		<ul>
			{
				team.map(
					({
						title,
						name,
						pronouns,
						description,
						email,
						image,
						contactFor,
					}) => (
						<li>
							<div class="image">
								<img src={image} />
							</div>
							<div class="content">
								<div class="member-info">
									<h2>{title}</h2>
									<h3>{name}</h3>
									<p>{pronouns}</p>
								</div>
								<p>{description}</p>
								<div class="contact">
									<p>{email}</p>
								</div>
								<p>
									<b>Contact for:</b> {contactFor}
								</p>
								<button>Full Bio</button>
							</div>
						</li>
					),
				)
			}
		</ul>
	</section>
	<section id="our-board">
		<h1>Our Board</h1>
		<ul>
			{
				board.map(({ title, name, pronouns, description, email, image }) => (
					<li>
						<div class="image">
							<img src={image} />
						</div>
						<div class="content">
							<div class="member-info">
								<h2>{title}</h2>
								<h3>{name}</h3>
								<p>{pronouns}</p>
							</div>
							<p>{description}</p>
							<div class="contact">
								<p>{email}</p>
							</div>
							<button>Full Bio</button>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</Base>

<style>
	section {
		background: var(--blue);
		h1 {
			font-size: 4rem;
		}
		ul {
			list-style: none;
			margin: 0;
			display: flex;
			gap: 4rem;
			flex-wrap: wrap;
			justify-content: space-evenly;
			width: 100%;
			margin-bottom: 2rem;
			li {
				height: 650px;
				width: 350px;
				display: flex;
				flex-direction: column;
				* {
					margin: 0;
				}

				border: 1px solid white;
				border-radius: 10px;

				div.image {
					width: 350px;
					height: 350px;
					img {
						width: 100%;
						height: 100%;
						border-radius: 10px;
						object-fit: cover;
					}
				}

				.content {
					display: flex;
					flex-direction: column;
					width: 100%;
					flex: 1;
					justify-content: space-between;
					padding: 1rem;
					h2 {
						font-size: 1rem;
						font-weight: normal;
					}
				}
			}
		}
		text-align: center;
		max-width: var(--xl);
		margin: auto;
	}
</style>
