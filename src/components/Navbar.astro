---
import { Icon } from "astro-icon/components";
import type { Route, SiteMetadata } from "../types";
import NavLinks from "./NavLinks.astro";
import { Image } from "astro:assets";

export const prerender = false;
interface Props {
	siteMetadata: SiteMetadata;
	routes: Route[];
}

const { siteMetadata, routes } = Astro.props;
---

<header data-drawer="inactive" data-prev-scroll="up">
	<a href="/" class="site-logo">
		<!-- TODO: add logo support -->
		{
			siteMetadata.logo ? (
				<Image
					src={siteMetadata.logo}
					alt={`The ${siteMetadata.title} logo.`}
					width={247}
					height={71}
				/>
			) : (
				<p>siteMetadata.title</p>
			)
		}
	</a>
	<nav class="desktop-nav">
		<div class="search">
			<Icon name="ri:search-line" />
			<input type="text" name="site-search" placeholder="Search..." value="" />
		</div>
		<div class="links"><NavLinks routes={routes} /></div>
	</nav>
	<button id="trigger"><Icon name={"ri:menu-fill"} /> </button>
	<nav class="mobile-nav">
		<div class="search">
			<Icon name="ri:search-line" size={32} />
			<input type="text" name="site-search" placeholder="Search..." value="" />
		</div>
		<div class="links">
			<NavLinks routes={routes} />
		</div>
	</nav>
</header>

<style lang="scss">
	@use "../styles/utils" as *;

	header {
		width: 100%;
		padding: 0 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-direction: row;
		position: fixed;
		top: 0;
		left: 0;
		background-color: var(--bg-color);
		height: 10rem;
		overflow: hidden;
		transition: height 300ms;
		filter: var(--shadow);
		z-index: 100;

		&[data-prev-scroll="down"] {
			height: 0;
		}

		a.site-logo {
			width: 12rem;
			& > img {
				width: 100%;
				height: 100%;
				object-fit: contain;
			}
		}

		nav.mobile-nav {
			/* hides on desktop */
			display: flex;
			justify-content: end;
			align-items: center;
			position: fixed;
			top: 0;
			right: 0;
			height: 100vh;
			width: 100vw;
			pointer-events: none;
			transition: all 300ms;

			@include breakpoint-up(md) {
				display: none;
			}

			div {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				height: 100%;
				justify-content: center;
				padding: 1rem;
				background: darkred;
				transform: translateX(100%);
				transition: all 300ms;
			}
		}

		&[data-drawer="active"] {
			nav.mobile-nav {
				backdrop-filter: blur(4px);
				pointer-events: initial;
				div {
					transform: translateX(0);
				}
			}
		}

		button#trigger {
			/* hides on desktop */
			display: block;
			@include breakpoint-up(md) {
				display: none;
			}
		}

		nav.desktop-nav {
			/* hides on mobile */
			display: none;
			@include breakpoint-up(md) {
				display: flex;
			}
			flex-direction: column;
			gap: 1.5rem;

			& > .search {
			}

			& > .links {
				display: flex;
				align-items: center;
				gap: 1rem;
			}
		}

		.search {
			width: 100%;
			padding: 0.5rem;
			background-color: var(--fg-color);
			border-radius: var(--round-edge);
			display: flex;
			align-items: center;
			gap: 0.5rem;
			& > svg {
			}

			& > input {
				border: 0;
				flex: 1;
				font-family: var(--header-font);
				font-weight: bold;
			}
		}
	}
</style>
<script>
	import { checkBreakpoint } from "../lib/";
	function updateDrawerState(e?: PointerEvent) {
		// console.log((e?.target as HTMLElement).tagName);
		if ((e?.target as HTMLElement).tagName.toLowerCase() === "a") {
			// prevents drawer retraction before navlink is clicked
			return;
		}

		const header = document.querySelector("header");
		const prevDrawerState = header?.dataset["drawer"];

		if (!header) {
			throw new Error("Couldn't update nav - header does not exist");
		}

		// set mobile expanded drawer
		if (checkBreakpoint("md")) {
			header.dataset["drawer"] = "inactive";
		} else {
			if (prevDrawerState === "inactive") {
				header.dataset["drawer"] = "active";
			} else {
				header.dataset["drawer"] = "inactive";
			}
		}
	}

	const trigger = document.getElementById("trigger");
	const mobileNav = document.querySelector<HTMLDivElement>("nav.mobile-nav");
	trigger?.addEventListener("pointerdown", updateDrawerState);
	mobileNav?.addEventListener("pointerdown", updateDrawerState);

	window.addEventListener("resize", () => {
		if (checkBreakpoint("md")) {
			updateDrawerState();
		}
	});

	let lastScrollPosition = window.scrollY;
	function updatePrevScroll() {
		const header = document.querySelector("header");
		if (!header) {
			throw new Error("Couldn't find the header element.");
		}
		const newScrollPosition = window.scrollY;
		header.dataset["prevScroll"] =
			lastScrollPosition > newScrollPosition || window.scrollY < 250
				? "up"
				: "down";
		lastScrollPosition = newScrollPosition;
	}

	window.addEventListener("scroll", updatePrevScroll);
</script>
