---
import sprayPaintBorder from "../assets/img/png-border-blue.png";
import { getImage } from "astro:assets";
import CssFilterConverter from "css-filter-converter";
import Color from "color";

interface Props {
  type: "cookie-cutter" | "spray-paint" | "squiggle";
  backgroundColor?: string;
  flip?: boolean;
}
const { type, backgroundColor, flip } = Astro.props;
const optimizedSprayPaint = await getImage({
  src: sprayPaintBorder,
  format: "webp",
});

const getBackgroundData = () => {
  if (type === "spray-paint") {
    return optimizedSprayPaint;
  }
};
const filter = CssFilterConverter.hexToFilter(Color(backgroundColor).hex());
console.log(filter);
---

<div class:list={["container", flip ? "flipped" : ""]}>
  <div
    class:list={["border", type]}
    style={{
      backgroundImage: `url(${getBackgroundData()?.src ?? ""})`,
      backgroundColor:
        type === "spray-paint" ? "rgba(0,0,0,0)" : backgroundColor,
      filter: type === "spray-paint" ? filter.color : "",
    }}
  >
  </div>
</div>

<style lang={"scss"} >
	.container {
		position: relative;
		height: 0;
	}

	.container.flipped {
		.border {
			transform: scaleY(-1);
			bottom: 2rem;
		}
	}
	.border {
		width: 100%;
		height: 2rem;
		z-index: 2;
	}

	.border.cookie-cutter {
		position: relative;
		top: 1.9rem;
		mask: conic-gradient(from -45deg at bottom,#0000,#000 1deg 89deg,#0000 90deg) 20%/2rem 100%;
	}

	.border.squiggle {
		position: relative;
		top: 1.9rem;
		mask:
			  radial-gradient(16px at 75% 100%,#0000 98%,#000) 50% calc(100% - 16px)/64px 100% repeat-x,
    radial-gradient(16px at 25% 50%,#000 99%,#0000 101%) bottom/64px 32px repeat-x
	}

	.border.spray-paint {
		height: 2rem;
		position: relative;
		background-repeat: repeat-x;
		background-size: contain;
	}
</style>
