---
import { Image } from "astro:assets";

interface Props {
	items: { image: string; alt: string; href: string }[];
	imageSize?: number;
}

const { items, imageSize = 250 } = Astro.props;
---

<ul>
	{
		items.map(({ image, alt, href }) => (
			<li>
				<a href={href}>
					<div class="image">
						<Image src={image} alt={alt} width={imageSize} height={imageSize} />
					</div>
				</a>
			</li>
		))
	}
</ul>

<style>
	ul {
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, 16rem);
		grid-auto-rows: 16rem;
		gap: 1rem;
		list-style: none;
		justify-content: space-evenly;

		.image {
			--size: 100%;
			width: var(--size);
			height: var(--size);
			img {
				width: 100%;
				height: 100%;
				object-fit: contain;
			}
		}
	}
</style>
