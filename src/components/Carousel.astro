---
import { Image } from "astro:assets";

interface Props {
	items: { image: string; alt: string; href: string }[];
	imageSize?: number;
}

const { items, imageSize = 250 } = Astro.props;
---

<ul>
	{
		items.map(({ image, alt, href }) => (
			<li>
				<a href={href}>
					<div class="image">
						<Image src={image} alt={alt} width={imageSize} height={imageSize} />
					</div>
				</a>
			</li>
		))
	}
</ul>

<style>
	ul {
		display: flex;
		flex-direction: row;
		gap: 1rem;
		list-style: none;
		justify-content: space-evenly;
		.image {
			width: 20rem;
			height: 20rem;
			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		}
	}
</style>
