---
import { Image } from "astro:assets";
import type { HTMLAttributes } from "astro/types";
import type { ImageMetadata } from "astro";

type Props = HTMLAttributes<"section"> & {
  title: string;
  description: string;
  backlink?: { text: string; url: string };
  image?: {
    src: ImageMetadata;
    alt: string;
  };
};

const {
  class: className,
  title,
  description,
  backlink,
  image,
  ...props
} = Astro.props;
---

<section class:list={["lg", className]} {...props}>
  <div class="container">
    <div class="text">
      {
        backlink && (
          <a class="implicit" href={backlink.url}>
            {"< Back to "}
            {backlink.text}
          </a>
        )
      }
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
    {
      image && (
        <div class="image">
          <Image {...image} />
        </div>
      )
    }
  </div>
</section>

<style lang="scss">
  .container {
    display: flex;
    padding: 2rem 1rem;
    gap: 2rem;
    .text {
      flex: 3;
      display: flex;
      flex-direction: column;

      a {
        font-size: 1.25rem;
        font-family: var(--header-font);
      }

      h1 {
        margin: 0;
        font-size: 3rem;
        font-family: var(--header-font);
        font-weight: 600;
        border-bottom: 2px solid currentColor;
        --border-margin: 1rem;
        padding-bottom: var(--border-margin);
        margin-bottom: var(--border-margin);
      }

      p {
        font-family: var(--header-font);
        margin: 0;
        font-size: 1.25rem;
      }

      hr {
        width: 100%;
        padding: 0 2rem;
      }
    }

    .image {
      flex: 1;
      img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
    }
  }
</style>
