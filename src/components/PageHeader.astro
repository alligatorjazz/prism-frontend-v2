---
import { Image } from "astro:assets";
import type { HTMLAttributes } from "astro/types";
import type { ImageMetadata } from "astro";

type Props = HTMLAttributes<"section"> & {
  title: string;
  description: string;
  backlink?: { text: string; url: string };
  image?: {
    src: ImageMetadata;
    alt: string;
  };
};
const {
  class: className,
  title,
  description,
  backlink,
  image,
  ...props
} = Astro.props;
---

<section class:list={["lg", className]} {...props}>
  <div class="container">
    <div class="text">
      {backlink && <a href={backlink.url}>{backlink.text}</a>}
      <h1>{title}</h1>
      <hr />
      <p>{description}</p>
    </div>
    {
      image && (
        <div class="image">
          <Image {...image} />
        </div>
      )
    }
  </div>
</section>

<style lang="scss">
  .container {
    display: flex;
    align-items: center;
    .text {
      flex: 2;
      display: flex;
      flex-direction: column;

      h1 {
        font-size: 2rem;
        font-family: var(--header-font);
        font-weight: bold;
      }

      p {
        font-size: 1.25rem;
      }

      hr {
        padding: 0 2rem;
      }
    }

    .image {
      flex: 1;
      img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
    }
  }
</style>
