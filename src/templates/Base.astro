---
import { getSiteMetadata } from "../api";
import MetadataLoader from "../components/MetadataLoader.astro";
import Navbar from "../components/Navbar.astro";
import type { Route, SurfaceMetadata } from "../types";
import "../styles/global.scss";
import NewsletterSignup from "../sections/NewsletterSignup.astro";
import Footer from "../sections/Footer.astro";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  pageMetadata: SurfaceMetadata;
}

const siteMetadata = await getSiteMetadata();
const routes: Route[] = [
  { type: "internal", path: "/404", displayName: "Quick Links" },
  { type: "internal", path: "/404", displayName: "About" },
  {
    type: "internal",
    displayName: "Get Involved",
    path: "/get-involved",
    children: [
      { type: "internal", path: "/task-forces", displayName: "Task Forces" },
    ],
  },
  { type: "internal", path: "/404", displayName: "Resources" },
  { type: "internal", path: "/404", displayName: "Events" },
  { type: "internal", path: "/404", displayName: "Donate", highlight: true },
];

const { pageMetadata, ...props } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Zilla+Slab:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <MetadataLoader pageMetadata={pageMetadata} siteMetadata={siteMetadata} />
    <link rel="stylesheet" href="/styles/theme.css" />
  </head>
  <body data-drawer="inactive" data-prev-scroll="up">
    <Navbar routes={routes} siteMetadata={siteMetadata} />
    <div class="spacer"></div>
    <div {...props}><slot /></div>
    <NewsletterSignup />
    <Footer />
  </body>
</html>

<style>
  .spacer {
    margin-bottom: 10rem;
  }
</style>
