---
import { strictSlug } from "../lib";
import LongFlag from "../components/LongFlag.astro";
const { title } = Astro.props;
---

<section id={strictSlug(title)} title={title}>
  <div class="flag">
    <LongFlag />
  </div>
  <div class="tagline"><slot /></div>
  <div class="spacer"></div>
</section>

<style lang="scss">
  @use "../styles/utils" as *;

  section {
    background: var(--bg-color);
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 1rem;

    &.full-width {
      width: 100%;
    }

    .flag {
      display: none;
      align-items: center;

      @include breakpoint-up(md) {
        display: flex;
      }
    }

    .tagline {
      display: flex;
      justify-content: center;
      flex: 1;
      white-space: nowrap;
      font-size: 2.5rem;
      font-family: var(--header-font);
      color: var(--fg-color);
      font-weight: 600;
      padding: 1rem;
      padding-bottom: 0;

      & > :global(p) {
        margin: 0;
      }
    }

    .spacer {
      flex: 1;
      display: none;
    }

    @include breakpoint-up(md) {
      display: grid;
      grid-template-columns: 2fr 2fr 2fr;

      padding: 2rem 0;
      .tagline {
        font-size: 4.5rem;
        line-height: 5rem;
      }

      .spacer {
        display: block;
      }
      .tagline p {
        background-color: green;
        margin: 0;
      }
    }
  }
</style>
