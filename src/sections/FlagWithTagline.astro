---
import slugify from "slugify";
import LongFlag from "../components/LongFlag.astro";
const { title, image } = Astro.props;
---

<section id={slugify(title, { strict: true })} title={title}>
	<div class="flag">
		<LongFlag />
	</div>
	<div class="tagline"><slot name="center" /></div>
	<div class="spacer"></div>
</section>

<style lang="scss">
	@use "../styles/utils" as *;

	section {
		background: var(--bg-color);
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;

		gap: 1rem;

		&.full-width {
			width: 100%;
		}

		.flag {
			display: none;
			align-items: center;

			@include breakpoint-up(md) {
				display: flex;
			}
		}

		.tagline {
			display: flex;
			justify-content: center;
			flex: 1;
			white-space: nowrap;
			font-size: 2.5rem;
			font-family: var(--header-font);
			color: var(--fg-color);
			font-weight: 600;
			/* background: #d123ff33 */
		}

		.spacer {
			flex: 1;
			/* background: #ff553333; */
			display: none;
		}

		@include breakpoint-up(md) {
			display: grid;
			grid-template-columns: 2fr 2fr 2fr;

			.tagline {
				font-size: 4.5rem;
				line-height: 5rem;
			}

			.spacer {
				display: block;
			}
		}
	}
</style>
