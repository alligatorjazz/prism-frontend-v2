---
import slugify from "slugify";
import { Image } from "astro:assets";
import PaperBorder1 from "../assets/img/paper-border-1.svg";
import PaperBorder2 from "../assets/img/paper-border-2.svg";

interface Props {
	title: string;
}

// TODO: implement tornPaper
const { title } = Astro.props;
---

<section id={slugify(title, { strict: true })} title={title}>
	<div class="header"><slot name="header" /></div>
	<div class={"paper"}>
		<div class="border top">
			<PaperBorder1 />
		</div>
		<!-- <Image src={tornPaper} alt={"A torn piece of notebook paper."} /> -->
		<!-- <div class="content"> -->
		<!-- 	<slot name="content" /> -->
		<!-- </div> -->
		<div class="border bottom">
			<PaperBorder2 />
		</div>
	</div>
</section>

<style lang={"scss"} >
	@use "../styles/utils" as *;

	section {
		background: var(--accent-color);
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 0rem;

		.header {
			margin: auto;
			text-align: center;
			& > * {
				margin: 0;
			}
		}

		.paper {
			max-width: var(--lg);

			img {
				width: 100%;
				height: ;
				object-fit: contain;
			}

			.border > svg {
				width: 100%;
			}

			.border.top {
				transform: scaleY(-1);
				img {
					object-fit: none;
					object-position: -64px;
				}
			}
			/* .content { */
			/* 	width: 100%; */
			/* } */
		}
	}
</style>
