---
import slugify from "slugify";
import { Image } from "astro:assets";
import tornPaper from "../assets/img/torn-notebook-paper.png";
interface Props {
	title: string;
}

// TODO: implement tornPaper
const { title } = Astro.props;
---

<section id={slugify(title, { strict: true })} title={title}>
	<div class="header"><slot name="header" /></div>
	<div class="content">
		<slot name="content" />
	</div>
</section>

<style lang={"scss"} >
	@use "../styles/utils" as *;

	section {
		background: var(--accent-color);
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 0rem;

		.header {
			margin: auto;
			text-align: center;
			& > * {
				margin: 0;
			}
		}

		.content {
			max-width: var(--lg);
			padding: 2rem;
			background: var(--fg-color);
		}
	}
</style>
