---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"section"> {}
const { ...props } = Astro.props;
---

<section {...props}>
	<div class="container"><slot /></div>
</section>

<style lang="scss">
	@use "../styles/utils" as *;
	.container {
		margin: auto;
		max-width: var(--xl);
	}
</style>
