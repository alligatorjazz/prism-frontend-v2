---
import { strictSlug } from "../lib";
import { type SectionProps } from "../types/sections";

// TODO: implement rich text here
type Props = { description: string } & SectionProps;
const { title, description } = Astro.props;
---

<section id={strictSlug(title)}>
	<div class="container">
		<div class="text">
			<h1>{title}</h1>
			{description.split("\n").map((line) => <p>{line}</p>)}
		</div>
		<div class="image">
			<img src={"https://picsum.photos/500"} />
		</div>
	</div>
</section>

<style lang="scss">
	@use "../styles/utils" as *;
	.container {
		max-width: var(--xl);
		display: flex;
		align-items: center;
		gap: 2rem;
		padding: 3rem 0;
		.text {
			flex: 1;
			text-align: left;
			h1 {
				padding-bottom: 1rem;
				font-size: 2.5rem;
				border-bottom: 2px solid white;
			}
			p {
				font-size: 1.5rem;
			}
		}

		.image {
			width: 25%;
			img {
				width: 100%;
				height: 100%;
				object-fit: contain;
			}
		}
	}
</style>
