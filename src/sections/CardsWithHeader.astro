---
import ColoredHeader from "../components/ColoredHeader.astro";
import { strictSlug } from "../lib";
import LinkCard from "../components/LinkCard.astro";
import type { Block } from "../types/payload";

type Props = Block<"CardsWithHeader">;
const { title, cards } = Astro.props;
---

<section id={strictSlug(title)}>
	<ColoredHeader
		><slot name="header"><h1 class="cards-header">{title}</h1></slot
		></ColoredHeader
	>
	<ul>
		{
			cards?.map((card) => (
				<li>
					<LinkCard {...card} />
				</li>
			))
		}
	</ul>
</section>

<style lang="scss">
	@use "../styles/utils" as *;

	.cards-header {
		text-align: center;
		font-size: 3rem;
		color: var(--fg-color);

		@include breakpoint-up(md) {
			font-size: 4rem;
		}
	}

	ul {
		background: lightgray;
		list-style: none;
		display: flex;
		justify-content: space-evenly;
		align-items: center;
		flex-wrap: wrap;
		gap: 2rem;

		@include breakpoint-up(md) {
			padding: 4rem;
		}
	}
</style>
